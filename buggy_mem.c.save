#include <stdio.h>
#include <stdlib.h>

int main() {
    // Error 1: Buffer Overflow (Desbordamiento)
    int *p = malloc(5 * sizeof(int));
    for (int i = 0; i <= 5; i++) {
        p[i] = i; 
    }

    // Error 2: Memory Leak (Fuga de memoria)
    void *q = malloc(100);

    // Error 3: Use-after-free (Usar después de liberar)
    free(p);
    printf("Valor despues de free: %d\n", p[0]);

    return 0;
}
